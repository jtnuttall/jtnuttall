# Variables
docker_tag := "jnuttall-resume-texlive"
docker_cmd := "docker run --rm -i --user=\"$(id -u):$(id -g)\" -v \"$PWD:/data\" -w /data " + docker_tag

# By default, build the image and both PDFs
@default: prepare (build "resume.tex") (build "coverletter.tex")

# Build the Docker image
prepare:
    docker build -t {{docker_tag}} .

# Standard build for any tex file
# Usage: just build resume.tex
build file:
    {{docker_cmd}} latexmk -xelatex -interaction=nonstopmode {{file}}

# Watch mode for any tex file
# Usage: just watch coverletter.tex
watch file:
    {{docker_cmd}} latexmk -xelatex -pvc -interaction=nonstopmode {{file}}

# Clean intermediate files
purge:
    {{docker_cmd}} latexmk -c resume.tex coverletter.tex

# Clean everything, including PDFs
clean:
    {{docker_cmd}} latexmk -C resume.tex coverletter.tex
