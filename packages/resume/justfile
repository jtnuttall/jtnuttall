docker_tag := "jnuttall-resume-texlive"
docker_cmd := "docker run --rm -i --user=\"$(id -u):$(id -g)\" -v \"$PWD:/data\" -w /data " + docker_tag

@default: prepare (build "resume.tex") (build "coverletter.tex")

prepare:
    docker build -t {{docker_tag}} .

build file:
    {{docker_cmd}} latexmk -lualatex -interaction=nonstopmode {{file}}

watch file:
    #!/usr/bin/env bash
    set -eo pipefail
    TEX_FILE="{{file}}"
    PDF_FILE="${TEX_FILE%.tex}.pdf"
    if [ ! -f "$PDF_FILE" ]; then
        {{docker_cmd}} latexmk -lualatex -interaction=nonstopmode "$TEX_FILE"
    fi
    zathura "$PDF_FILE" > /dev/null 2>&1 &
    {{docker_cmd}} latexmk -lualatex -pvc -view=none -interaction=nonstopmode "$TEX_FILE"

purge:
    {{docker_cmd}} latexmk -c resume.tex coverletter.tex

clean:
    {{docker_cmd}} latexmk -C resume.tex coverletter.tex
